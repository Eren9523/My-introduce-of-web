rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false; 
    }
    
    match /board_messages/{messageId} {
      allow read: if true;
      allow create: if request.auth != null 
                    && request.resource.data.keys().hasAll(['user', 'content', 'time', 'createdAt', 'parentId'])
                    && request.resource.data.user is string
                    && request.resource.data.content is string
                    && request.resource.data.time is string
                    && (request.resource.data.parentId is string || request.resource.data.parentId == null)
                    && request.resource.data.createdAt == request.time;
      allow update: if false;
      allow delete: if request.auth != null; // basic allow delete for demo
    }
  }
}
